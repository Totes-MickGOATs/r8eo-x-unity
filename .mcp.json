{
  "mcpServers": {
    "UnityMCP": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "@anthropic/unity-mcp@latest"
      ],
      "env": {}
    },
    "coplay-mcp": {
      "command": "cmd",
      "args": [
        "/c",
        "npx",
        "-y",
        "coplay-mcp@latest"
      ],
      "env": {}
    },
    "fathom": {
      "type": "http",
      "url": "http://localhost:19876/mcp"
    }
  }
}