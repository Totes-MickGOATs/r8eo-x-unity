{
  "env": {
    "MAX_MCP_OUTPUT_TOKENS": "10000",
    "ENABLE_TOOL_SEARCH": "true",
    "DISABLE_NON_ESSENTIAL_MODEL_CALLS": "1"
  },
  "outputStyle": "concise",
  "permissions": {
    "allow": [
      "Read",
      "Edit",
      "Write",
      "Glob",
      "Grep",
      "Agent",
      "Skill",
      "WebSearch",
      "WebFetch",
      "ToolSearch",
      "TaskCreate",
      "TaskGet",
      "TaskList",
      "TaskUpdate",
      "TaskStop",
      "TaskOutput",
      "EnterPlanMode",
      "ExitPlanMode",
      "EnterWorktree",
      "ExitWorktree",
      "ListMcpResourcesTool",
      "ReadMcpResourceTool",
      "NotebookEdit",
      "AskUserQuestion",
      "CronCreate",
      "CronDelete",
      "CronList",
      "Bash(*)",
      "mcp__UnityMCP__read_console",
      "mcp__UnityMCP__manage_scene",
      "mcp__UnityMCP__manage_gameobject",
      "mcp__UnityMCP__manage_components",
      "mcp__UnityMCP__manage_asset",
      "mcp__UnityMCP__manage_editor",
      "mcp__UnityMCP__manage_script",
      "mcp__UnityMCP__manage_material",
      "mcp__UnityMCP__manage_prefabs",
      "mcp__UnityMCP__manage_camera",
      "mcp__UnityMCP__manage_animation",
      "mcp__UnityMCP__manage_ui",
      "mcp__UnityMCP__manage_graphics",
      "mcp__UnityMCP__manage_shader",
      "mcp__UnityMCP__manage_texture",
      "mcp__UnityMCP__manage_vfx",
      "mcp__UnityMCP__manage_packages",
      "mcp__UnityMCP__manage_tools",
      "mcp__UnityMCP__manage_probuilder",
      "mcp__UnityMCP__manage_script_capabilities",
      "mcp__UnityMCP__manage_scriptable_object",
      "mcp__UnityMCP__find_gameobjects",
      "mcp__UnityMCP__find_in_file",
      "mcp__UnityMCP__create_script",
      "mcp__UnityMCP__delete_script",
      "mcp__UnityMCP__validate_script",
      "mcp__UnityMCP__script_apply_edits",
      "mcp__UnityMCP__apply_text_edits",
      "mcp__UnityMCP__execute_menu_item",
      "mcp__UnityMCP__execute_custom_tool",
      "mcp__UnityMCP__batch_execute",
      "mcp__UnityMCP__refresh_unity",
      "mcp__UnityMCP__run_tests",
      "mcp__UnityMCP__get_test_job",
      "mcp__UnityMCP__get_sha",
      "mcp__UnityMCP__set_active_instance",
      "mcp__UnityMCP__debug_request_context",
      "mcp__ide__getDiagnostics"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "bash -c 'CMD=$(jq -r \".tool_input.command // empty\"); if echo \"$CMD\" | grep -q \"git commit\"; then find \"$CLAUDE_PROJECT_DIR\" -name \"*.pyc\" -delete && find \"$CLAUDE_PROJECT_DIR\" -name \"__pycache__\" -type d -exec rm -rf {} + 2>/dev/null; fi; exit 0'"
          },
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/guard-master-commit.sh\""
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-on-save.sh\""
          }
        ]
      },
      {
        "matcher": "EnterPlanMode",
        "hooks": [{
          "type": "command",
          "command": "touch /tmp/cc-plan-mode-active"
        }]
      },
      {
        "matcher": "ExitPlanMode",
        "hooks": [{
          "type": "command",
          "command": "rm -f /tmp/cc-plan-mode-active"
        }]
      }
    ],
    "SubagentStop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/subagent-post-stop.sh\""
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/stop-uncommitted-check.sh\""
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/session-start.sh\""
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/pre-compact-context.sh\""
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/lint-session-stop.sh\""
          }
        ]
      }
    ],
    "WorktreeCreate": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/worktree-setup.sh\""
          }
        ]
      }
    ]
  },
  "worktree": {
    "symlinkDirectories": [
      ".venv",
      "Library"
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/statusline.sh\"",
    "padding": 0
  }
}
