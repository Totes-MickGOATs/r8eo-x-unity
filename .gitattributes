# Auto-detect text files and normalize line endings
* text=auto eol=lf
# Scripts
*.sh text eol=lf
*.bash text eol=lf
*.py text eol=lf
# Config
*.json text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
*.toml text eol=lf
*.cfg text eol=lf
*.ini text eol=lf
# Documentation
*.md text eol=lf
*.txt text eol=lf
# =============================================================================
# LFS — Large binary files (engine-agnostic)
# =============================================================================
# Images
*.png filter=lfs diff=lfs merge=lfs -text
*.jpg filter=lfs diff=lfs merge=lfs -text
*.jpeg filter=lfs diff=lfs merge=lfs -text
*.bmp filter=lfs diff=lfs merge=lfs -text
*.tga filter=lfs diff=lfs merge=lfs -text
