#!/bin/bash
# Pre-commit hook: master guard + lint staged files
# Install: git config core.hooksPath .githooks

# ── Main branch guard ────────────────────────────────────────────────────────
CURRENT_BRANCH=$(git branch --show-current 2>/dev/null)
if [ "$CURRENT_BRANCH" = "main" ] && [ -z "$ALLOW_MASTER_COMMIT" ]; then
    echo "BLOCKED: Direct commits to main are not allowed."
    echo ""
    echo "All code changes must go through feature branches + PRs."
    echo ""
    echo "Quick start:"
    echo "  just worktree-create <task-name>"
    echo "  # ... develop on feat/<task> branch ..."
    echo "  git push -u origin feat/<task>"
    echo "  gh pr create --base main"
    echo ""
    echo "Full workflow guide: .agents/skills/branch-workflow/SKILL.md"
    echo ""
    echo "Bypass (release/hotfix only): ALLOW_MASTER_COMMIT=1 git commit ..."
    exit 1
fi

# ── Staged file detection ────────────────────────────────────────────────────
STAGED_PY=$(git diff --cached --name-only --diff-filter=ACM -- '*.py')

# Lint staged Python files
if [ -n "$STAGED_PY" ] && uv run ruff --version &>/dev/null; then
    echo "Linting staged Python files..."
    if ! echo "$STAGED_PY" | xargs uv run ruff check 2>&1; then
        echo ""
        echo "Python lint errors found. Fix with: uv run ruff check --fix"
        exit 1
    fi
fi

# ── Conventional commit message format check (via commit-msg hook) ─────────

# ── Engine-specific checks ────────────────────────────────────────────────────
ENGINE_HOOK=".githooks/pre-commit-engine.sh"
if [ -f "$ENGINE_HOOK" ]; then
    source "$ENGINE_HOOK"
fi

# ── Test file existence check (Layer 1: coverage enforcement) ────────────────
# Warn if staged production C# scripts have no corresponding test file.
STAGED_CS=$(git diff --cached --name-only --diff-filter=ACM -- '*.cs')

# ── Roslyn analyzer build (Layer 3: analyzer diagnostics) ────────────────────
if [ -n "$STAGED_CS" ] && [ -z "${SKIP_ANALYZER_CHECK:-}" ]; then
    echo "Running Roslyn analyzer build..."
    if ! just analyze 2>&1; then
        echo ""
        echo "BLOCKED: Roslyn analyzer errors found. Fix diagnostics above."
        echo "Bypass: SKIP_ANALYZER_CHECK=1 git commit ..."
        exit 1
    fi
fi

if [ -n "$STAGED_CS" ]; then
    MISSING_TESTS=0
    while IFS= read -r file; do
        # Skip non-production files: Tests/, Editor/, .asmdef files
        case "$file" in
            Assets/Tests/*|*/Editor/*|*.asmdef) continue ;;
        esac
        # Only check files under Assets/Scripts/
        case "$file" in
            Assets/Scripts/*) ;;
            *) continue ;;
        esac

        # Extract class name from filename (e.g., Drivetrain.cs -> Drivetrain)
        baseName=$(basename "$file" .cs)

        # Look for matching test files
        found=0
        for testDir in Assets/Tests/EditMode Assets/Tests/PlayMode; do
            if [ -d "$testDir" ]; then
                # Check for *ClassName*Tests.cs or *ClassName*Test.cs
                for match in "$testDir"/*"${baseName}"*Tests.cs "$testDir"/*"${baseName}"*Test.cs; do
                    if [ -f "$match" ]; then
                        found=1
                        break 2
                    fi
                done
            fi
        done

        # If no file match, try grepping for the class name in test files
        if [ "$found" -eq 0 ]; then
            if grep -rql "$baseName" Assets/Tests/ --include="*.cs" 2>/dev/null; then
                found=1
            fi
        fi

        if [ "$found" -eq 0 ]; then
            if [ "$MISSING_TESTS" -eq 0 ]; then
                echo ""
                echo "=== Test Coverage Warnings ==="
            fi
            MISSING_TESTS=$((MISSING_TESTS + 1))
            echo "WARNING: No test file found for modified script: $file"
            echo "  Expected: Assets/Tests/EditMode/${baseName}Tests.cs or similar"
            echo "  TDD requires tests for all production code. Write tests before pushing."
            echo ""
        fi
    done <<< "$STAGED_CS"

    if [ "$MISSING_TESTS" -gt 0 ]; then
        echo "  $MISSING_TESTS script(s) without test coverage detected."
        echo "  This is a warning — commit proceeds, but write tests before pushing."
        echo "=== End Test Coverage Warnings ==="
        echo ""
    fi
fi

# ── Coverage ratchet + Assert audit (Layer 2) ────────────────────────────────
if [ -n "$STAGED_CS" ] && [ -z "${SKIP_COVERAGE_CHECK:-}" ]; then
    if ! echo "$STAGED_CS" | uv run python scripts/tools/pre_commit_checks.py 2>&1; then
        echo ""
        echo "BLOCKED: Pre-commit checks failed. See details above."
        echo "Bypass: SKIP_COVERAGE_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── Line limit check (Layer 4) ──────────────────────────────────────────────
if [ -n "$STAGED_CS" ] && [ -z "${SKIP_LINE_LIMIT:-}" ]; then
    LINE_VIOLATIONS=0
    ALLOWLIST="R8EOXInputActions.cs"
    while IFS= read -r file; do
        basename_file=$(basename "$file")
        # Skip allowlisted files
        case "$basename_file" in
            $ALLOWLIST) continue ;;
        esac
        lines=$(wc -l < "$file" | tr -d ' ')
        if [ "$lines" -gt 200 ]; then
            if [ "$LINE_VIOLATIONS" -eq 0 ]; then
                echo ""
                echo "=== Line Limit Violations ==="
            fi
            echo "FAIL: $file ($lines lines, limit=200)"
            LINE_VIOLATIONS=$((LINE_VIOLATIONS + 1))
        fi
    done <<< "$STAGED_CS"
    if [ "$LINE_VIOLATIONS" -gt 0 ]; then
        echo ""
        echo "BLOCKED: $LINE_VIOLATIONS file(s) exceed the 200-line limit."
        echo "Split large files before committing. Bypass: SKIP_LINE_LIMIT=1 git commit ..."
        exit 1
    fi
fi

# ── C# Syntax check (Layer 5) ─────────────────────────────────────────────────
if [ -n "$STAGED_CS" ] && [ -z "${SKIP_SYNTAX_CHECK:-}" ]; then
    echo "Running C# syntax check..."
    SYNTAX_ERRORS=0
    while IFS= read -r file; do
        if ! bash scripts/tools/syntax-check-csharp.sh "$file" 2>&1; then
            SYNTAX_ERRORS=$((SYNTAX_ERRORS + 1))
        fi
    done <<< "$STAGED_CS"
    if [ "$SYNTAX_ERRORS" -gt 0 ]; then
        echo ""
        echo "BLOCKED: C# syntax check failed. See details above."
        echo "Bypass: SKIP_SYNTAX_CHECK=1 git commit ..."
        exit 1
    fi
fi

# ── C# Policy lint (Layer 6) ──────────────────────────────────────────────────
if [ -n "$STAGED_CS" ] && [ -z "${SKIP_POLICY_CHECK:-}" ]; then
    echo "Running C# policy lint..."
    if ! uv run python scripts/tools/lint_csharp_policy.py --staged 2>&1; then
        echo ""
        echo "BLOCKED: C# policy violations found. See details above."
        echo "  Direct Debug.Log*, FindObject, Resources.Load, or GUID refs in runtime assemblies."
        echo "  Use RuntimeLog from R8EOX.Shared instead of Debug.Log*."
        echo "Bypass: SKIP_POLICY_CHECK=1 git commit ..."
        exit 1
    fi
fi
