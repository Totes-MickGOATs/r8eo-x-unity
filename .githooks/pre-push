#!/bin/bash
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# ── Main branch push guard ───────────────────────────────────────────────────
# Block direct pushes to main — use PRs instead.
# Bypass (release only): ALLOW_MASTER_PUSH=1 git push ...
# Read stdin for push info (must consume it before other checks)
PUSH_REFS=""
while read local_ref local_sha remote_ref remote_sha; do
    PUSH_REFS="${PUSH_REFS}${local_ref} ${local_sha} ${remote_ref} ${remote_sha}\n"
    if echo "$remote_ref" | grep -qE 'refs/heads/main$'; then
        if [ -z "$ALLOW_MASTER_PUSH" ]; then
            echo "ERROR: Direct push to main is blocked. Use a PR."
            echo "Bypass (release only): ALLOW_MASTER_PUSH=1 git push ..."
            exit 1
        fi
    fi
done

# ── Auto-rebase feature branches onto latest main ────────────────────────────
# Prevents pushing branches behind main, which causes merge queue churn.
CURRENT_BRANCH=$(git branch --show-current)
if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
    git fetch origin main --quiet 2>/dev/null || true
    if ! git merge-base --is-ancestor origin/main HEAD 2>/dev/null; then
        echo "Pre-push: rebasing onto origin/main..."
        if ! git rebase origin/main --quiet 2>/dev/null; then
            echo "ERROR: Rebase onto origin/main failed. Resolve conflicts first."
            git rebase --abort 2>/dev/null
            exit 1
        fi
        echo "Pre-push: rebase successful"
    fi
fi

# ── Test runner for changed files (Layer 2: module-based coverage enforcement) ──
# Run Unity tests for all tests in affected modules before allowing push.
# Changing any file in a module runs ALL tests for that module + transitive dependents.
# Bypass: SKIP_TEST_CHECK=1 git push ...

if [ -n "$SKIP_TEST_CHECK" ]; then
    echo "SKIP_TEST_CHECK set — skipping pre-push test check."
else
    # Determine the remote tracking branch to diff against
    TRACKING_BRANCH=$(git rev-parse --abbrev-ref '@{upstream}' 2>/dev/null)
    if [ -z "$TRACKING_BRANCH" ]; then
        TRACKING_BRANCH="origin/main"
    fi

    # Get changed .cs files (production scripts only, not test or editor scripts)
    CHANGED_CS=$(git diff --name-only "$TRACKING_BRANCH"...HEAD -- 'Assets/Scripts/**/*.cs' 2>/dev/null | \
        grep -v '/Editor/' | grep -v '/Tests/' | grep -v '\.asmdef$')

    if [ -n "$CHANGED_CS" ]; then
        # Resolve module-based test filters via resolver script
        RESOLVER_OUTPUT=$(echo "$CHANGED_CS" | uv run python scripts/tools/resolve_module_tests.py --format shell --editmode-only --with-dependencies 2>/dev/null)
        RESOLVER_EXIT=$?

        if [ "$RESOLVER_EXIT" -eq 1 ]; then
            echo "WARNING: Test resolver error — falling back to push-allowed."
            echo "  Run manually: echo \"<file>\" | uv run python scripts/tools/resolve_module_tests.py"
        elif [ "$RESOLVER_EXIT" -eq 2 ]; then
            echo "No module-mapped tests for changed scripts — push allowed."
        else
            # Parse EDITMODE_FILTER from resolver output
            EDITMODE_FILTER=$(echo "$RESOLVER_OUTPUT" | grep '^EDITMODE_FILTER=' | cut -d= -f2-)
            MODULES=$(echo "$RESOLVER_OUTPUT" | grep '^MODULES=' | cut -d= -f2-)
            PLAYMODE_FILTER=$(echo "$RESOLVER_OUTPUT" | grep '^PLAYMODE_FILTER=' | cut -d= -f2-)

            if [ -n "$EDITMODE_FILTER" ]; then
                # Check if Unity is available in PATH
                UNITY_CMD=""
                if command -v Unity &>/dev/null; then
                    UNITY_CMD="Unity"
                elif command -v unity &>/dev/null; then
                    UNITY_CMD="unity"
                fi

                if [ -z "$UNITY_CMD" ]; then
                    echo "WARNING: Unity not found in PATH — skipping pre-push test run."
                    echo "  CI will run tests after push. Ensure tests pass before merging."
                else
                    # ── Compile check (fast-fail before tests) ──────────────────
                    COMPILE_LOG=$(mktemp /tmp/unity-compile-XXXXXX.log)
                    echo "Compile check..."
                    timeout 60 "$UNITY_CMD" -batchmode -nographics -quit \
                        -projectPath . \
                        -logFile "$COMPILE_LOG" 2>&1
                    COMPILE_EXIT=$?
                    if [ "$COMPILE_EXIT" -ne 0 ] && [ "$COMPILE_EXIT" -ne 124 ]; then
                        echo ""
                        echo "ERROR: Compilation failed. Fix errors before pushing."
                        echo ""
                        grep -E "error CS|CompilerError|Scripts have compiler" "$COMPILE_LOG" | head -20
                        rm -f "$COMPILE_LOG"
                        exit 1
                    fi
                    rm -f "$COMPILE_LOG"
                    echo "Compilation clean."
                    echo ""

                    echo "Running EditMode tests for modules: $MODULES"
                    echo "  Filter: $EDITMODE_FILTER"
                    echo ""

                    # Run tests with 120-second timeout
                    TEST_LOG=$(mktemp /tmp/unity-tests-XXXXXX.log)
                    timeout 120 "$UNITY_CMD" -batchmode -nographics -runTests \
                        -testPlatform EditMode \
                        -testFilter "$EDITMODE_FILTER" \
                        -projectPath . \
                        -testResults /dev/null \
                        -logFile "$TEST_LOG" 2>&1
                    TEST_EXIT=$?

                    if [ "$TEST_EXIT" -eq 124 ]; then
                        echo "WARNING: Tests timed out after 120 seconds. Push allowed."
                        echo "  Check test results in CI."
                    elif [ "$TEST_EXIT" -ne 0 ]; then
                        echo ""
                        echo "ERROR: Tests FAILED (exit code $TEST_EXIT). Push blocked."
                        echo ""
                        echo "  Failed modules: $MODULES"
                        echo "  Filter: $EDITMODE_FILTER"
                        echo ""
                        echo "  Fix failing tests before pushing."
                        echo "  Bypass (emergency only): SKIP_TEST_CHECK=1 git push ..."
                        echo ""
                        echo "Last 30 lines of Unity log:"
                        tail -30 "$TEST_LOG"
                        rm -f "$TEST_LOG"
                        exit 1
                    else
                        echo "All module tests passed."
                        rm -f "$TEST_LOG"
                    fi

                    # Advisory: PlayMode tests to run manually
                    if [ -n "$PLAYMODE_FILTER" ]; then
                        echo ""
                        echo "Advisory: PlayMode tests should also pass (run manually or in CI):"
                        echo "  $PLAYMODE_FILTER"
                    fi
                fi
            else
                echo "No EditMode tests resolved for changed scripts — push allowed."
            fi
        fi
    fi
fi
