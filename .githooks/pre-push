#!/bin/bash
command -v git-lfs >/dev/null 2>&1 || { printf >&2 "\n%s\n\n" "This repository is configured for Git LFS but 'git-lfs' was not found on your path. If you no longer wish to use Git LFS, remove this hook by deleting the 'pre-push' file in the hooks directory (set by 'core.hookspath'; usually '.git/hooks')."; exit 2; }
git lfs pre-push "$@"

# ── Main branch push guard ───────────────────────────────────────────────────
# Block direct pushes to main — use PRs instead.
# Bypass (release only): ALLOW_MASTER_PUSH=1 git push ...
# Read stdin for push info (must consume it before other checks)
PUSH_REFS=""
while read local_ref local_sha remote_ref remote_sha; do
    PUSH_REFS="${PUSH_REFS}${local_ref} ${local_sha} ${remote_ref} ${remote_sha}\n"
    if echo "$remote_ref" | grep -qE 'refs/heads/main$'; then
        if [ -z "$ALLOW_MASTER_PUSH" ]; then
            echo "ERROR: Direct push to main is blocked. Use a PR."
            echo "Bypass (release only): ALLOW_MASTER_PUSH=1 git push ..."
            exit 1
        fi
    fi
done

# ── Auto-rebase feature branches onto latest main ────────────────────────────
# Prevents pushing branches behind main, which causes merge queue churn.
CURRENT_BRANCH=$(git branch --show-current)
if [ "$CURRENT_BRANCH" != "main" ] && [ "$CURRENT_BRANCH" != "master" ]; then
    git fetch origin main --quiet 2>/dev/null || true
    if ! git merge-base --is-ancestor origin/main HEAD 2>/dev/null; then
        echo "Pre-push: rebasing onto origin/main..."
        if ! git rebase origin/main --quiet 2>/dev/null; then
            echo "ERROR: Rebase onto origin/main failed. Resolve conflicts first."
            git rebase --abort 2>/dev/null
            exit 1
        fi
        echo "Pre-push: rebase successful"
    fi
fi

# --- Module-gated test check ---
if [[ "${SKIP_TEST_CHECK:-}" == "1" ]]; then
  echo "pre-push: SKIP_TEST_CHECK=1 — skipping module-gated tests"
else
  # Get changed files vs main
  changed_files=$(git diff --name-only main...HEAD -- '*.cs')
  if [[ -n "$changed_files" ]]; then
    # Resolve which test classes need to run
    resolve_output=$(echo "$changed_files" | uv run python scripts/tools/resolve_module_tests.py 2>/dev/null || true)
    editmode_filter=$(echo "$resolve_output" | grep '^EDITMODE_FILTER=' | cut -d= -f2-)
    test_classes=$(echo "$editmode_filter" | tr '|' '\n' | grep -v '^$' || true)
    if [[ -n "$test_classes" ]]; then
      echo "pre-push: Module-gated tests required:"
      echo "$test_classes" | while read -r cls; do echo "  - $cls"; done

      # Only run if Unity is available
      unity_path="${UNITY_PATH:-Unity}"
      if command -v "$unity_path" &>/dev/null; then
        filter=$(echo "$test_classes" | paste -sd '|' -)
        echo "pre-push: Running tests..."
        "$unity_path" -batchmode -nographics -runTests -testPlatform EditMode \
          -projectPath . -testFilter "$filter" -testResults /dev/null 2>&1 || {
          echo "pre-push: TESTS FAILED — push BLOCKED. Fix failing tests before pushing."
          echo "  Bypass (emergency only): SKIP_TEST_CHECK=1 git push"
          exit 1
        }
        echo "pre-push: All module tests passed."
      else
        echo "pre-push: Unity not found at '$unity_path' — test execution skipped (advisory)"
        echo "  Tests required when UNITY_PATH is set. Set it to enable hard test gating."
        echo "  Suppress this message: SKIP_TEST_CHECK=1 git push"
      fi
    else
      echo "pre-push: No module-gated tests needed for changed files."
    fi
  fi
fi
